# development | staging | production
CONFORMEO_APP_ENV=development

# PostgreSQL connection string used by FastAPI and bootstrap scripts.
CONFORMEO_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/conformeo

# Required outside development. Replace this placeholder in every real environment.
CONFORMEO_AUTH_TOKEN_SECRET=development-only-change-me

CONFORMEO_AUTH_ACCESS_TOKEN_TTL_MINUTES=480
CONFORMEO_CORS_ALLOW_ORIGINS=["http://localhost:4200","http://localhost:8100","http://127.0.0.1:4200","http://127.0.0.1:8100"]
